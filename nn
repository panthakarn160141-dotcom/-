<body class="min-h-screen flex flex-col justify-center items-center bg-background p-margin-mobile">
<!-- Auth Background Decorative Element -->
<div class="fixed inset-0 z-0 opacity-10 pointer-events-none overflow-hidden">
<div class="absolute -top-1/4 -right-1/4 w-[600px] h-[600px] rounded-full bg-primary-container blur-3xl"></div>
<div class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] rounded-full bg-secondary-container blur-3xl"></div>
</div>
<!-- Login Container -->
<main class="relative z-10 w-full max-w-[440px] bg-surface-container-lowest border border-outline-variant rounded-xl shadow-lg p-lg md:p-xl">
<!-- Brand Header -->
<header class="flex flex-col items-center mb-xl">
<div class="w-16 h-16 bg-primary-container rounded-xl flex items-center justify-center mb-md shadow-md">
<span class="material-symbols-outlined text-white text-[40px]" data-icon="build">build</span>
</div>
<h1 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-primary tracking-tight">
                TechFix Manager
            </h1>
<p class="font-body-md text-body-md text-on-surface-variant mt-xs">ระบบจัดการร้านและผู้ดูแลระบบ</p>
</header>
<!-- Login Form -->
<form action="dashboard.html" class="space-y-lg" id="loginForm">
<!-- Email/Username Input -->
<div class="space-y-xs">
<label class="font-label-lg text-label-lg text-on-surface" for="username">ชื่อผู้ใช้ หรือ อีเมล</label>
<div class="relative flex items-center focus-ring border border-outline-variant rounded-lg bg-surface h-touch-target transition-all px-md">
<span class="material-symbols-outlined text-on-surface-variant mr-md" data-icon="person">person</span>
<input class="w-full bg-transparent border-none focus:ring-0 p-0 font-body-md text-body-md text-on-surface placeholder:text-outline" id="username" placeholder="ระบุชื่อผู้ใช้ของคุณ" required="" type="text">
</div>
</div>
<!-- Password Input -->
<div class="space-y-xs">
<div class="flex justify-between items-center">
<label class="font-label-lg text-label-lg text-on-surface" for="password">รหัสผ่าน</label>
<a class="font-label-lg text-label-lg text-primary hover:underline" href="forgot-password.html">ลืมรหัสผ่าน?</a>
</div>
<div class="relative flex items-center focus-ring border border-outline-variant rounded-lg bg-surface h-touch-target transition-all px-md">
<span class="material-symbols-outlined text-on-surface-variant mr-md" data-icon="lock">lock</span>
<input class="w-full bg-transparent border-none focus:ring-0 p-0 font-body-md text-body-md text-on-surface placeholder:text-outline" id="password" placeholder="ระบุรหัสผ่านของคุณ" required="" type="password">
<button class="ml-xs text-on-surface-variant flex items-center justify-center w-touch-target h-touch-target -mr-md hover:bg-surface-variant/20 rounded-full transition-colors" onclick="togglePassword()" type="button">
<span class="material-symbols-outlined" data-icon="visibility" id="pw-toggle-icon">visibility</span>
</button>
</div>
</div>
<!-- Remember Me & Security Meta -->
<div class="flex items-center space-x-md">
<label class="relative flex items-center cursor-pointer group">
<input class="peer sr-only" id="remember-me" type="checkbox">
<div class="w-12 h-6 bg-surface-variant rounded-full peer peer-checked:bg-primary-container transition-colors duration-200"></div>
<div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform duration-200 peer-checked:translate-x-6"></div>
<span class="ml-sm font-body-md text-body-md text-on-surface-variant select-none">จดจำฉันในระบบ</span>
</label>
</div>
<!-- Submit Button -->
<button class="w-full h-touch-target bg-primary text-on-primary font-label-lg text-label-lg rounded-lg shadow-md hover:bg-primary-container active:scale-[0.98] transition-all flex items-center justify-center space-x-sm" type="submit">
<span class="">เข้าสู่ระบบ</span>
<span class="material-symbols-outlined" data-icon="login">login</span>
</button>
<button class="w-full h-touch-target mt-lg border border-primary text-primary font-label-lg text-label-lg rounded-lg hover:bg-primary-container hover:text-white active:scale-[0.98] transition-all flex items-center justify-center space-x-sm" onclick="window.location.href='repair-status.html'" type="button">
<span class="material-symbols-outlined" data-icon="search">search</span>
<span class="">ตรวจสอบสถานะการซ่อม (สำหรับลูกค้า)</span>
</button>
</form>
<!-- Footer Info -->
<footer class="mt-xl pt-lg border-t border-outline-variant text-center">
<p class="font-label-sm text-label-sm text-outline flex items-center justify-center">
<span class="material-symbols-outlined text-[14px] mr-1" data-icon="security">security</span>
                ระบบจัดการที่มีความปลอดภัยสูงและเข้ารหัสแบบครบวงจร
            </p>
</footer>
</main>
<!-- Support Link -->
<div class="mt-lg relative z-10">
<button class="flex items-center space-x-sm px-lg py-sm bg-surface-variant/30 hover:bg-surface-variant/50 rounded-full transition-colors" onclick="window.location.href='support.html'">
<span class="material-symbols-outlined text-primary text-[18px]" data-icon="help_outline">help_outline</span>
<span class="font-label-lg text-label-lg text-on-secondary-fixed-variant">ฝ่ายสนับสนุนระบบ</span>
</button>
</div>
<!-- Background Graphic (Visualizer Context) -->
<div class="fixed bottom-0 right-0 p-lg hidden lg:block opacity-20 group">
<div class="grid grid-cols-3 gap-3 p-4 bg-white border border-outline-variant rounded-xl">
<div class="w-3 h-3 rounded-full bg-primary"></div>
<div class="w-3 h-3 rounded-full bg-primary"></div>
<div class="w-3 h-3 rounded-full bg-primary"></div>
<div class="w-3 h-3 rounded-full bg-outline"></div>
<div class="w-3 h-3 rounded-full bg-outline"></div>
<div class="w-3 h-3 rounded-full bg-outline"></div>
<div class="w-3 h-3 rounded-full bg-outline"></div>
<div class="w-3 h-3 rounded-full bg-outline"></div>
<div class="w-3 h-3 rounded-full bg-outline"></div>
</div>
<p class="text-right font-label-sm text-label-sm text-outline mt-2 italic">มาตรฐานความปลอดภัยระดับอุตสาหกรรม</p>
</div>
<script>
        function togglePassword() {
            const input = document.getElementById('password');
            const icon = document.getElementById('pw-toggle-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }

        const loginForm = document.getElementById('loginForm');
        loginForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const btn = this.querySelector('button[type="submit"]');
            if(this.checkValidity()) {
                const originalContent = btn.innerHTML;
                btn.innerHTML = '<div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>';
                btn.disabled = true;
                
                // Simulate network request
                setTimeout(() => {
                    window.location.href = 'dashboard.html';
                }, 800);
            }
        });

        // Service Worker Registration for PWA
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => {
                    console.log('ServiceWorker registration failed: ', err);
                });
            });
        }
    </script>
